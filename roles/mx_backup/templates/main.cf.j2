{{ ansible_managed | comment }}
# MX secondario (backup) - solo relay, nessuna consegna locale.

# --- Identità ---
myhostname = {{ mx_backup_fqdn }}
myorigin = $myhostname
mydestination =
local_transport = error:local delivery disabled on backup MX
inet_interfaces = all
inet_protocols = ipv4

compatibility_level = 3
biff = no
append_dot_mydomain = no
readme_directory = no

# --- TLS in ricezione (smtpd) ---
smtpd_tls_cert_file = {{ mx_backup_cert_dir }}/fullchain.pem
smtpd_tls_key_file = {{ mx_backup_cert_dir }}/privkey.pem
smtpd_tls_security_level = may
smtpd_tls_protocols = !SSLv2, !SSLv3, !TLSv1, !TLSv1.1
smtpd_tls_ciphers = high
smtpd_tls_loglevel = 1
smtpd_tls_received_header = yes
smtpd_tls_session_cache_database = btree:${data_directory}/smtpd_scache

# --- TLS in invio verso il primario (smtp client) ---
smtp_tls_security_level = may
smtp_tls_protocols = !SSLv2, !SSLv3, !TLSv1, !TLSv1.1
smtp_tls_ciphers = high
smtp_tls_loglevel = 1
smtp_tls_session_cache_database = btree:${data_directory}/smtp_scache

# --- Anti open-relay / hardening SMTP ---
smtpd_helo_required = yes
disable_vrfy_command = yes
smtpd_delay_reject = yes
smtpd_banner = $myhostname ESMTP

# --- Relay: SOLO per i domini elencati, nessun altro ---
relay_domains = {{ mx_backup_relay_domains | join(', ') }}
transport_maps = hash:/etc/postfix/mx_backup_transport

# ATTENZIONE - backscatter: nessuna validazione dei singoli destinatari
# qui, solo del dominio (relay_domains). Il server accetta quindi
# temporaneamente mail anche per indirizzi inesistenti, che poi il
# primario rifiuterà in fase di relay - a quel punto QUESTO server
# genera un bounce verso il mittente (rischio backscatter se il
# mittente è falsificato). Per ridurlo, aggiungi qui una
# relay_recipient_maps (mappa statica o query al DB del primario,
# aperto solo a questo host) con i soli recipient validi.
smtpd_relay_restrictions =
    permit_mynetworks,
    reject_unauth_destination

smtpd_recipient_restrictions =
    reject_non_fqdn_recipient,
    reject_unknown_recipient_domain,
    reject_rbl_client zen.spamhaus.org,
    permit

# --- Coda: quanto ritentare prima di rimbalzare al mittente ---
maximal_queue_lifetime = {{ mx_backup_maximal_queue_lifetime }}
bounce_queue_lifetime = {{ mx_backup_bounce_queue_lifetime }}

# --- Anti abuso / DoS di base ---
smtpd_client_connection_rate_limit = 30
anvil_rate_time_unit = 60s
message_size_limit = 26214400
