---
# Qualsiasi host in [mailservers] nell'inventario riceve automaticamente
# il ruolo mailserver (Postfix + Dovecot hardenizzati).
role_mailserver: true

# Se installi la posta con ispmail.sh (vedi 02-mailserver.yml) invece del ruolo
# mailserver di questo repo, decommenta e valorizza queste righe:
# mailserver_manage_service: false
# ispmail_fqdn: "mail.example.com"        # hostname dei protocolli SMTP/IMAP
# ispmail_webmail_fqdn: "webmail.example.com"  # opzionale: ServerAlias dedicato per Roundcube via browser
# firewall_allowed_tcp_ports: [80, 443]   # servono a Roundcube/rspamd-ui via Apache
#
# Se il certificato TLS viene provisionato da un ruolo esterno (es.
# ansible-dns con validazione DNS-01) invece che da certbot dentro
# ispmail.sh, roles/ispmail se lo aspetta di default come file "piatti"
# sotto /etc/ssl/acme/<nome>.fullchain.pem e <nome>.key. Se <nome> non
# coincide con ispmail_fqdn (es. certificato sul dominio apex/wildcard
# invece che sul sottodominio mail.*), indicalo esplicitamente:
# ispmail_cert_name: "example.com"
# Oppure, se i path non seguono affatto questa convenzione, sovrascrivili
# direttamente:
# ispmail_cert_fullchain_src: "/etc/ssl/acme/mail.example.com.fullchain.pem"
# ispmail_cert_privkey_src: "/etc/ssl/acme/mail.example.com.key"
#
# Pannello web opzionale per gestire domini/mailbox/alias, su vhost dedicato
# (non un path su ispmail_fqdn - vedi README per i compromessi: download
# solo HTTP, nessun checksum pubblicato). Raggiungibile solo dalle reti in
# ispmail_admin_allow_networks (default in roles/ispmail_admin/defaults):
# ispmail_admin_enabled: true
# ispmail_admin_fqdn: "ispmail.example.com"
# ispmail_admin_allow_networks: ["203.0.113.0/24"]
#
# Domini ospitati che devono presentare un certificato TLS diverso da
# ispmail_fqdn quando un client si connette al loro hostname (SNI), invece
# di condividere il certificato del server principale. Serve già un
# certificato per ognuno in /etc/ssl/acme/ (emesso da ansible-dns) e un
# DNS che punti sni_hostname a questo host:
# ispmail_sni_domains:
#   - domain: "otherdomain.com"
#     sni_hostname: "mail.otherdomain.com"
#     cert_name: "otherdomain.com"   # default: = domain
#
# Chiavi DKIM per rspamd, una per dominio ospitato (ispmail.sh predispone
# l'infrastruttura ma non le genera da solo). Generate una sola volta
# (mai rigenerate ai run successivi, per non invalidare il DNS già
# pubblicato): il riepilogo finale mostra il record TXT da pubblicare
# per ognuna.
# ispmail_dkim_domains:
#   - domain: "example.com"
#     selector: "mail"
#
# Quota di default per casella (sintassi Dovecot). Vale per le caselle con
# quota=0 nel DB; un valore in byte nella colonna virtual_users.quota (via
# ISPmail Admin) la sovrascrive per la singola casella. Default: 5G.
# ispmail_quota_default: "2G"
#
# CardDAV/CalDAV con Radicale + plugin RCMCardDAV in Roundcube: rubrica e
# calendario personali per ogni mailbox, più rubrica e calendario condivisi
# per ogni dominio ospitato, con le stesse credenziali della mailbox. I
# client esterni (smartphone, Thunderbird) usano
# https://<ispmail_fqdn>/radicale/ - vedi
# roles/ispmail_carddav/defaults/main.yml.
# ispmail_carddav_enabled: true
