; Esempio di inventario. Sostituisci con i tuoi host reali.
; Al primo giro, se sul server esiste ancora solo root, usa:
;   ansible-playbook playbook.yml -u root -k -e ansible_user=root
; e valorizza harden_create_admin_user per creare l'utente sudo,
; poi passa a quello per i run successivi.

[all:vars]
ansible_python_interpreter=/usr/bin/python3

[webservers]
;web01 ansible_host=10.0.0.10

[mailservers]
;mail01 ansible_host=10.0.0.11

[dbservers]
;db01 ansible_host=10.0.0.12

[baseline:children]
webservers
mailservers
dbservers
